{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "files": ["env.d.ts"],
  "references": [
    { "path": "./src/modules/global" },
    { "path": "./src/modules/workspace" },
    { "path": "./src/modules/templates" }
  ],
  "compilerOptions": {
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@/*": ["./src/*"],
      "@global": ["./src/modules/global"],
      "@workspace": ["./src/modules/workspace"],
      "@templates": ["./src/modules/templates"]
    },
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo"
  }
}
