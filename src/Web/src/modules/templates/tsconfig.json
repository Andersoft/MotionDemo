{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "../../../dist/out-tsc/modules/templates",
    "tsBuildInfoFile": "../../../node_modules/.tmp/tsconfig.modules.templates.tsbuildinfo",
    "paths": {
      "@/*": ["../../*"],
      "@global": ["../global"],
      "@entities": ["./entities"],
      "@widgets": ["./widgets"],
      "@features": ["./features"],
      "@pages": ["./pages"],
      "@shared": ["./shared"]
    }
  },
  "include": ["**/*.ts", "**/*.vue"],
  "exclude": ["__tests__"],
  "references": [{ "path": "../global" }]
}
